; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GMAT"
run/main_scene="res://scenes/mainMenu/main.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://assets/images/icon.svg"

[autoload]

DataManager="*res://db/scripts/data_manager.gd"
MuscleData="*res://db/scripts/muscleData.gd"
MenuManager="*res://autoload/MenuManager.gd"
NotificationManager="*res://autoload/NotificationManager.gd"
SessionManager="*res://db/scripts/hypertrophySession/sessionManager.gd"
SceneRegistry3d="*res://autoload/SceneRegistry3D.gd"
SettingsGlobal="*res://autoload/settings_global.gd"

[display]

window/size/viewport_width=800
window/size/viewport_height=480
window/stretch/mode="viewport"

[gui]

theme/default_font_multichannel_signed_distance_field=true

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
