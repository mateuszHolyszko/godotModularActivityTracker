[sub_resource type="GDScript" id="GDScript_fvhb6"]
script/source = "extends ColorRect

@onready var shader_material: ShaderMaterial = material

func _ready():
	# Connect to settings signals if shader exists
	if shader_material and SettingsGlobal:
		# Apply initial values
		_update_bleed_shader_params(SettingsGlobal.get_all_bleed_settings())
		
		# Connect to signals
		SettingsGlobal.bleed_shader_updated.connect(_update_bleed_shader_params)
		
		# Optional: Connect to resolution changes if needed
		SettingsGlobal.settings_changed.connect(_on_settings_changed)

func _update_bleed_shader_params(params: Dictionary):
	if not shader_material:
		return
	
	shader_material.set_shader_parameter(\"bleed_strength\", params[\"bleed_strength\"])
	shader_material.set_shader_parameter(\"pixel_width\", params[\"pixel_width\"])
	shader_material.set_shader_parameter(\"brightness_threshold\", params[\"brightness_threshold\"])
	shader_material.set_shader_parameter(\"shift_multiplier\", params[\"shift_multiplier\"])
	
	# Also handle shader toggle if your shader supports it
	if shader_material.get_shader_parameter(\"enabled\") != null:
		shader_material.set_shader_parameter(\"enabled\", SettingsGlobal.get_shader_enabled())

func _on_settings_changed():
	# If resolution changes, update pixel width to match
	var resolution = SettingsGlobal.get_resolution()
	if shader_material and resolution:
		shader_material.set_shader_parameter(\"pixel_width\", resolution.x)
"

