[sub_resource type="GDScript" id="GDScript_lg21n"]
script/source = "extends ColorRect

@export var fade_out_time := 0.2
@export var fade_in_time := 0.25
@onready var CRT_shader = $\"../../CanvasLayer/BleedPass/BackBufferCopy/CRTPass\"

var tween: Tween

signal fade_out_completed
signal fade_in_completed

func _ready():
	color = Color.BLACK
	modulate.a = 0.0
	set_anchors_preset(Control.PRESET_FULL_RECT)
	mouse_filter = Control.MOUSE_FILTER_IGNORE

func fade_out():
	if tween:
		tween.kill()
	
	mouse_filter = Control.MOUSE_FILTER_STOP
	
	tween = create_tween()
	# Tween fade out
	tween.tween_property(self, \"modulate:a\", 1.0, fade_out_time)
	
	# Tween shader intensity if shader exists and has intensity property
	if CRT_shader and CRT_shader.material:
		# Start intensity tween at the same time
		tween.parallel().tween_property(CRT_shader.material, \"shader_parameter/intensity\", -1.5, fade_out_time)
	
	tween.finished.connect(_on_fade_out_finished)

func _on_fade_out_finished():
	fade_out_completed.emit()

func fade_in():
	if tween:
		tween.kill()
	
	tween = create_tween()
	# Tween fade in
	tween.tween_property(self, \"modulate:a\", 0.0, fade_in_time)
	
	# Tween shader intensity back to original value
	if CRT_shader and CRT_shader.material:
		tween.parallel().tween_property(CRT_shader.material, \"shader_parameter/intensity\", 0.2, fade_in_time)
	
	tween.finished.connect(_on_fade_in_finished)

func _on_fade_in_finished():
	mouse_filter = Control.MOUSE_FILTER_IGNORE
	fade_in_completed.emit()
	
func play_refresh_animation():
	if tween:
		tween.kill()
	
	mouse_filter = Control.MOUSE_FILTER_STOP
	
	# Start fully black
	modulate.a = 1.0
	
	tween = create_tween()
	tween.tween_property(self, \"modulate:a\", 0.0, fade_in_time * 2)
	
	# Add shader intensity animation for refresh effect
	if CRT_shader and CRT_shader.material:
		# Start with intense negative value
		CRT_shader.material.set_shader_parameter(\"intensity\", -1.5)
		# Tween back to normal
		tween.parallel().tween_property(CRT_shader.material, \"shader_parameter/intensity\", 0.2, fade_in_time * 2)
	
	tween.finished.connect(func():
		mouse_filter = Control.MOUSE_FILTER_IGNORE
	)
"

[sub_resource type="GDScript" id="GDScript_i55mm"]
script/source = "extends PointLight2D

# Current target state
var target_position: Vector2 = Vector2.ZERO
var has_target: bool = false

# Smoothing speed (tweak this)
@export var follow_speed: float = 10.0

func _ready():
	SettingsGlobal.focus_light = self
	visible = false

func _process(delta):
	if not has_target:
		return
	
	# Smoothly move toward target
	global_position = global_position.lerp(target_position, follow_speed * delta)


# Called by MainControl when focus changes
func set_focus(focus: Control):
	if focus == null:
		has_target = false
		visible = false
		return
	
	has_target = true
	visible = true
	
	# Calculate center of the control
	target_position = focus.global_position + focus.size / 2
	
	# Scale light based on control size
	texture_scale = focus.size.length() / 200.0
"

