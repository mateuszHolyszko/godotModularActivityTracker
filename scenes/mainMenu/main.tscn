[sub_resource type="GDScript" id="GDScript_t2721"]
script/source = "extends ColorRect

@onready var shader_material: ShaderMaterial = material

func _ready():
	# Connect to settings signals if shader exists
	if shader_material and SettingsGlobal:
		# Apply initial values
		_update_crt_shader_params(SettingsGlobal.get_all_crt_settings())
		
		# Connect to signals
		SettingsGlobal.crt_shader_updated.connect(_update_crt_shader_params)
		
		# Connect to shader toggle separately
		SettingsGlobal.shader_toggled.connect(_on_shader_toggled)
		
		# Optional: Connect to resolution changes
		SettingsGlobal.settings_changed.connect(_on_settings_changed)

func _update_crt_shader_params(params: Dictionary):
	if not shader_material:
		return
	
	shader_material.set_shader_parameter(\"intensity\", params[\"intensity\"])
	shader_material.set_shader_parameter(\"pixel_width\", params[\"pixel_width\"])
	shader_material.set_shader_parameter(\"pixel_height\", params[\"pixel_height\"])
	shader_material.set_shader_parameter(\"scanline_thickness\", params[\"scanline_thickness\"])
	shader_material.set_shader_parameter(\"scanline_darkness\", params[\"scanline_darkness\"])
	shader_material.set_shader_parameter(\"phosphor_thickness\", params[\"phosphor_thickness\"])
	shader_material.set_shader_parameter(\"phosphor_strength\", params[\"phosphor_strength\"])
	shader_material.set_shader_parameter(\"flicker_speed\", params[\"flicker_speed\"])
	shader_material.set_shader_parameter(\"flicker_strength\", params[\"flicker_strength\"])
	
	# Apply shader toggle
	if shader_material.get_shader_parameter(\"enabled\") != null:
		shader_material.set_shader_parameter(\"enabled\", SettingsGlobal.get_shader_enabled())

func _on_shader_toggled(enabled: bool):
	if shader_material and shader_material.get_shader_parameter(\"enabled\") != null:
		shader_material.set_shader_parameter(\"enabled\", enabled)

func _on_settings_changed():
	# If resolution changes, update pixel dimensions
	var resolution = SettingsGlobal.get_resolution()
	if shader_material and resolution:
		shader_material.set_shader_parameter(\"pixel_width\", resolution.x)
		shader_material.set_shader_parameter(\"pixel_height\", resolution.y)
"

