[ext_resource type="Script" path="res://scenes/InitMenu/LoadingPanel.gd" id="4_e8rkk"]

[sub_resource type="GDScript" id="GDScript_xfebl"]
script/source = "extends MeshInstance3D

var base_speed = 0.5
var speed_multiplier = 5.0
var transition_zone = 10.0 # Degrees for smooth transition

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta):
	# Get current rotation in degrees (convert from radians)
	var current_rotation_deg = rad_to_deg(rotation.y)
	
	# Normalize angle to -180 to 180 range
	current_rotation_deg = fmod(current_rotation_deg, 360)
	if current_rotation_deg > 180:
		current_rotation_deg -= 360
	elif current_rotation_deg < -180:
		current_rotation_deg += 360
	
	# Calculate angle distance from front (0 degrees)
	var angle_from_front = abs(current_rotation_deg)
	
	# Determine speed multiplier based on angle
	if angle_from_front <= 45:
		# Front zone - normal speed
		var current_multiplier = 1.0
		rotation.y += delta * base_speed * current_multiplier
	else:
		# Outside front - double speed
		rotation.y += delta * base_speed * speed_multiplier
	
	# Optional: Print current angle for debugging
	# print(\"Angle: \", current_rotation_deg, \" Speed multiplier: \", current_multiplier)
"

