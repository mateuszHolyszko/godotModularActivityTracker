[sub_resource type="GDScript" id="GDScript_arard"]
script/source = "extends Control

# ── node refs ────────────────────────────────────────────────────────────────
@onready var target_button    : ChooseMenuButton    = $Panel/HC/TargetButton
@onready var name_input       : KeyboardInputButton = $Panel/HC/MainContent/VC/LabelPanel/ExerciseNameLabel
@onready var input_bot_range  : ValueInput          = $Panel/HC/MainContent/VC/InputsPanelContainer/HC/InputPanelRepRange/VC/HC2/InputBotRange
@onready var input_top_range  : ValueInput          = $Panel/HC/MainContent/VC/InputsPanelContainer/HC/InputPanelRepRange/VC/HC2/InputTopRange
@onready var bodyweight_button: OptionButton = $Panel/HC/MainContent/VC/InputsPanelContainer/HC/InputPanelBodyweight/VC/InputBodyWeight
@onready var isolation_button : OptionButton = $Panel/HC/MainContent/VC/InputsPanelContainer/HC/InputPanelIsolation/VC/InputIsolation
@onready var intensity_button : ChooseMenuButton    = $Panel/HC/MainContent/VC/InputsPanelContainer/HC/InputPanelIntensity/VC/ChooseMenuButton
@onready var curve_button     : ChooseMenuButton    = $Panel/HC/MainContent/VC/InputsPanelContainer/HC/InputPanelCurve/VC/ChooseMenuButton
@onready var delete_button    : Button              = $Panel/HC/CRUDE_Panel/VC/DeleteButton
@onready var save_button      : Button              = $Panel/HC/CRUDE_Panel/VC/SaveButtom

# ── state ────────────────────────────────────────────────────────────────────
## Null = new unsaved exercise. Non-null = loaded from the database.
var _exercise: ExerciseResource = null

# ── lifecycle ────────────────────────────────────────────────────────────────
func _ready() -> void:
	save_button.pressed.connect(_on_save_pressed)
	delete_button.pressed.connect(_on_delete_pressed)

	# All inputs that affect save-button validity
	name_input.text_changed.connect(_on_any_changed)
	target_button.option_changed.connect(func(opt): _apply_muscle_color(opt))
	intensity_button.option_changed.connect(_on_any_changed)
	curve_button.option_changed.connect(_on_any_changed)
	bodyweight_button.item_selected.connect(_on_any_changed)
	isolation_button.item_selected.connect(_on_any_changed)
	# ValueInput doesn't block saving but wire for completeness
	input_bot_range.value_changed.connect(_on_any_changed)
	input_top_range.value_changed.connect(_on_any_changed)

	_refresh_buttons()

# ── public API ───────────────────────────────────────────────────────────────
func load_exercise_resource(exercise: ExerciseResource) -> void:
	_exercise = exercise

	name_input.current_text = exercise.name
	name_input.text         = exercise.name

	target_button.current_option = exercise.target_muscle
	target_button.text           = exercise.target_muscle
	_apply_muscle_color(exercise.target_muscle)

	var intensity_str: String = ExerciseResource.Intensity.keys()[exercise.intensity]
	intensity_button.current_option = intensity_str
	intensity_button.text = intensity_str

	var tension_str: String = ExerciseResource.TensionProfile.keys()[exercise.tension_profile]
	curve_button.current_option = tension_str
	curve_button.text = tension_str

	bodyweight_button.select(0 if exercise.bodyweight else 1)
	isolation_button.select(0 if exercise.isolation  else 1)

	input_bot_range.value = exercise.rep_range.x
	input_bot_range.update_text()
	input_top_range.value = exercise.rep_range.y
	input_top_range.update_text()

	_refresh_buttons()

# ── validation ───────────────────────────────────────────────────────────────
func _all_fields_filled() -> bool:
	if name_input.current_text.strip_edges().is_empty():
		return false
	if target_button.current_option.is_empty():
		return false
	if intensity_button.current_option.is_empty():
		return false
	if curve_button.current_option.is_empty():
		return false
	if bodyweight_button.selected == -1:
		return false
	if isolation_button.selected == -1:
		return false
	return true

func _refresh_buttons() -> void:
	save_button.disabled   = not _all_fields_filled()
	delete_button.disabled = _exercise == null

# ── signal callbacks ─────────────────────────────────────────────────────────
# option_changed(String), text_changed(String), value_changed(float)
# — default param lets one handler cover all three signatures
func _on_any_changed(_val = null) -> void:
	_refresh_buttons()

# ── button handlers ──────────────────────────────────────────────────────────
func _on_save_pressed() -> void:
	if not _all_fields_filled():
		return

	var tension  : ExerciseResource.TensionProfile = ExerciseResource.TensionProfile[curve_button.current_option]
	var intensity: ExerciseResource.Intensity      = ExerciseResource.Intensity[intensity_button.current_option]
	var bw: bool = bodyweight_button.get_item_text(bodyweight_button.selected) == \"True\"
	var iso: bool = isolation_button.get_item_text(isolation_button.selected) == \"True\"
	var rep_bot  : int  = int(input_bot_range.value)
	var rep_top  : int  = int(input_top_range.value)

	if _exercise == null:
		# CREATE
		_exercise = DataManager.create_exercise(
			name_input.current_text.strip_edges(),
			target_button.current_option,
			bw, tension, intensity, iso,
			rep_bot, rep_top
		)
	else:
		# UPDATE
		_exercise.name            = name_input.current_text.strip_edges()
		_exercise.target_muscle   = target_button.current_option
		_exercise.bodyweight      = bw
		_exercise.isolation       = iso
		_exercise.tension_profile = tension
		_exercise.intensity       = intensity
		_exercise.rep_range       = Vector2i(rep_bot, rep_top)
		DataManager.save_exercises()

	NotificationManager.notify(\"Exercise Saved\")
	_refresh_buttons()

func _on_delete_pressed() -> void:
	if _exercise == null:
		return
	DataManager.delete_exercise(_exercise.id)
	_exercise = null
	NotificationManager.notify(\"Exercise Deleted\")
	queue_free()


func _apply_muscle_color(muscle: String) -> void:
	var color: Color = MuscleData.get_color(muscle)
	var is_default: bool = muscle.is_empty() or not MuscleData.MUSCLE_COLORS.has(muscle)

	for btn in [target_button, name_input]:
		if is_default:
			btn.remove_theme_color_override(\"font_color\")
			btn.remove_theme_stylebox_override(\"normal\")
			btn.remove_theme_stylebox_override(\"hover\")
			btn.remove_theme_stylebox_override(\"pressed\")
		else:
			var style := StyleBoxFlat.new()
			style.bg_color = color
			btn.add_theme_color_override(\"font_color\", Color.BLACK)
			btn.add_theme_stylebox_override(\"normal\",  style)
			# slightly darkened tint for hover/pressed feedback
			var style_hover := style.duplicate()
			style_hover.bg_color = color.darkened(0.1)
			btn.add_theme_stylebox_override(\"hover\", style_hover)
			var style_pressed := style.duplicate()
			style_pressed.bg_color = color.darkened(0.2)
			btn.add_theme_stylebox_override(\"pressed\", style_pressed)
"

