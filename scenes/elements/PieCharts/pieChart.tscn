[sub_resource type="GDScript" id="GDScript_unxei"]
script/source = "extends Control

# Config: get from root PieChart node
@export_range(0,100) var radius_percent: float = 90.0
@export var start_angle: float = -PI / 2
const ARC_SEGMENTS := 48

func _draw():
	var root = get_parent().get_parent().get_parent() # PieChart node
	if root.entries.size() == 0:
		return

	var panel_size = size
	var center = panel_size / 2.0
	var radius = min(panel_size.x, panel_size.y) * (radius_percent / 200.0)

	var current_angle = start_angle

	# Draw pie slices only - NO connection lines here anymore
	for entry in root.entries:
		var angle_span = (entry.value / root.total_value) * TAU

		var points := PackedVector2Array()
		points.append(center)

		for i in range(ARC_SEGMENTS + 1):
			var t = float(i) / ARC_SEGMENTS
			var ang = lerp(entry.start_angle, entry.end_angle, t)
			var p = center + Vector2(cos(ang), sin(ang)) * radius
			points.append(p)

		draw_colored_polygon(points, entry.color)
		current_angle += angle_span
	
	# REMOVED: root.draw_connections(get_canvas_item())
	# Connections are now handled by LineContainer and MarkerContainer
"

