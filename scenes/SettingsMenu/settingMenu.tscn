[sub_resource type="GDScript" id="GDScript_7qov3"]
script/source = "extends VBoxContainer

var userListRow_path = \"res://scenes/SettingsMenu/UserListRow.tscn\"
@onready var addUserButton = $\"../AddUserButton\"

func _ready():
	addUserButton.text_changed.connect(on_add_user)
	create_user_list()

func create_user_list():
	# Clear any existing children first (if needed)
	for child in get_children():
		child.queue_free()
	
	# Get all users from DataManager
	var users = DataManager.users
	
	# Create a row for each user if users exist
	if users != null and not users.is_empty():
		for user in users:
			# Load the scene
			var user_list_row_scene = load(userListRow_path)
			
			# Instantiate the scene
			var user_list_row = user_list_row_scene.instantiate()
			
			# Set the user property on the instantiated scene
			user_list_row.user = user
			
			# Add it as a child
			add_child(user_list_row)

func refresh_user_list():
	create_user_list()

func on_add_user(name):
	# Reset text since it gets automaticly assigned to output string from keyboard input
	addUserButton.text=\"\"
	print(\"add user: \",name)
	
	DataManager.create_user(name)
	
	refresh_user_list()
"

[sub_resource type="GDScript" id="GDScript_j0lx5"]
script/source = "extends HBoxContainer

@onready var SwitchShaderButton = $ToggleShadersButton
@onready var ShaderStateLabel = $LabelShaderState

func _ready():
	# Set initial label to reflect current saved state
	_update_label(SettingsGlobal.get_shader_enabled())
	
	# Connect button press to toggle function
	SwitchShaderButton.pressed.connect(_on_toggle_shaders_pressed)
	
	# Listen to SettingsGlobal signal so the label stays in sync
	# even if something else changes the shader state
	SettingsGlobal.shader_toggled.connect(_on_shader_toggled)

func _on_toggle_shaders_pressed():
	var new_state = not SettingsGlobal.get_shader_enabled()
	SettingsGlobal.set_shader_enabled(new_state)
	# set_shader_enabled() emits shader_toggled, which drives everything below

func _on_shader_toggled(shader_enabled: bool):
	# Apply visibility to the canvas layer (stops GPU draw calls)
	if SettingsGlobal.render_canvas_layer:
		SettingsGlobal.render_canvas_layer.visible = shader_enabled
	_update_label(shader_enabled)

func _update_label(shader_enabled: bool):
	ShaderStateLabel.text = \"Shaders: ON\" if shader_enabled else \"Shaders: OFF\"
"

