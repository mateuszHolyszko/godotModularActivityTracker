[sub_resource type="GDScript" id="GDScript_sa2lb"]
script/source = "extends VBoxContainer

# References to custom InputValue components
@onready var bleed_strength_input = $HC/VC/HC/BleedStrengthInput
@onready var bleed_strength_range = $HC/VC/HC/BleedStrengthRange
@onready var brightness_threshold_input = $HC/VC/HC2/BrightnessThresholdInput
@onready var brightness_threshold_range = $HC/VC/HC2/BrightnessThresholdRange
@onready var shift_multiplier_input = $HC/VC/HC3/ShiftMultiplierInput
@onready var shift_multiplier_range = $HC/VC/HC3/ShiftMultiplierRange

@onready var reset_button = $HC/ResetButton

func _ready():
	# Configure InputValue components with their ranges
	_setup_input_components()
	
	# Connect signals
	_connect_signals()
	
	# Load current settings
	_load_current_settings()

func _setup_input_components():
	# Bleed Strength: 0.0 - 2.0, step 0.01
	bleed_strength_input.min_value = 0.0
	bleed_strength_input.max_value = 2.0
	bleed_strength_input.step = 0.01
	bleed_strength_range.text = \"0-2\"
	
	# Brightness Threshold: 0.0 - 1.0, step 0.01
	brightness_threshold_input.min_value = 0.0
	brightness_threshold_input.max_value = 1.0
	brightness_threshold_input.step = 0.01
	brightness_threshold_range.text = \"0-1\"
	
	# Shift Multiplier: 1.0 - 16.0, step 0.1
	shift_multiplier_input.min_value = 1.0
	shift_multiplier_input.max_value = 16.0
	shift_multiplier_input.step = 0.1
	shift_multiplier_range.text = \"1-16\"

func _connect_signals():
	# Connect value_confirmed signals (fires when user confirms the value)
	bleed_strength_input.value_confirmed.connect(_on_bleed_strength_confirmed)
	brightness_threshold_input.value_confirmed.connect(_on_brightness_threshold_confirmed)
	shift_multiplier_input.value_confirmed.connect(_on_shift_multiplier_confirmed)
	
	# Reset button
	reset_button.pressed.connect(_on_reset_pressed)

func _load_current_settings():
	# Load current values from SettingsGlobal into InputValue components
	bleed_strength_input.value = SettingsGlobal.get_bleed_strength()
	bleed_strength_input.update_text()
	brightness_threshold_input.value = SettingsGlobal.get_brightness_threshold()
	brightness_threshold_input.update_text()
	shift_multiplier_input.value = SettingsGlobal.get_shift_multiplier()
	shift_multiplier_input.update_text()

# ========== VALUE CONFIRMED HANDLERS ==========

func _on_bleed_strength_confirmed(value: float):
	SettingsGlobal.set_bleed_strength(value)
	print(\"Bleed strength set to: \", value)

func _on_brightness_threshold_confirmed(value: float):
	SettingsGlobal.set_brightness_threshold(value)
	print(\"Brightness threshold set to: \", value)

func _on_shift_multiplier_confirmed(value: float):
	SettingsGlobal.set_shift_multiplier(value)
	print(\"Shift multiplier set to: \", value)

# ========== RESET FUNCTION ==========

func _on_reset_pressed():
	# Reset to default values from SettingsGlobal constants
	var defaults = SettingsGlobal.DEFAULT_BLEED_SETTINGS
	
	bleed_strength_input.value = defaults[\"bleed_strength\"]
	brightness_threshold_input.value = defaults[\"brightness_threshold\"]
	shift_multiplier_input.value = defaults[\"shift_multiplier\"]
	bleed_strength_input.update_text()
	brightness_threshold_input.update_text()
	shift_multiplier_input.update_text()
	
	# Update settings with the reset values
	SettingsGlobal.set_bleed_strength(defaults[\"bleed_strength\"])
	SettingsGlobal.set_brightness_threshold(defaults[\"brightness_threshold\"])
	SettingsGlobal.set_shift_multiplier(defaults[\"shift_multiplier\"])
	
	print(\"Bleed shader settings reset to defaults\")
"

[sub_resource type="GDScript" id="GDScript_k7jpj"]
script/source = "extends VBoxContainer

# References to custom InputValue components
@onready var intensity_input = $HC/VC/HC/IntensityInput
@onready var intensity_range = $HC/VC/HC/IntensityRange
@onready var scanline_thickness_input = $HC/VC/HC2/ScanlineThicknessInput
@onready var scanline_thickness_range = $HC/VC/HC2/ScanlineThicknessRange
@onready var scanline_darkness_input = $HC/VC/HC3/ScanlineDarknessInput
@onready var scanline_darkness_range = $HC/VC/HC3/ScanlineDarknessRange
@onready var phosphor_thickness_input = $HC/VC/HC4/PhosphorThicknessInput
@onready var phosphor_thickness_range = $HC/VC/HC4/PhosphorThicknessRange
@onready var phosphor_strength_input = $HC/VC/HC5/PhosphorStrengthInput
@onready var phosphor_strength_range = $HC/VC/HC5/PhosphorStrengthRange
@onready var flicker_speed_input = $HC/VC/HC6/FlickerSpeedInput
@onready var flicker_speed_range = $HC/VC/HC6/FlickerSpeedRange
@onready var flicker_strength_input = $HC/VC/HC7/FlickerStrengthInput
@onready var flicker_strength_range = $HC/VC/HC7/FlickerStrengthRange
@onready var reset_button = $HC/ResetButton

func _ready():
	# Configure InputValue components with their ranges
	_setup_input_components()
	
	# Connect signals
	_connect_signals()
	
	# Load current settings
	_load_current_settings()

func _setup_input_components():
	# Intensity: range from your shader defaults
	intensity_input.min_value = 0.0
	intensity_input.max_value = 2.0
	intensity_input.step = 0.01
	intensity_range.text = \"0-2\"
	
	# Scanline Thickness: 0.5 - 0.9
	scanline_thickness_input.min_value = 0.5
	scanline_thickness_input.max_value = 0.9
	scanline_thickness_input.step = 0.01
	scanline_thickness_range.text = \"0.5-0.9\"
	
	# Scanline Darkness: 0.2 - 0.5
	scanline_darkness_input.min_value = 0.2
	scanline_darkness_input.max_value = 0.5
	scanline_darkness_input.step = 0.01
	scanline_darkness_range.text = \"0.2-0.5\"
	
	# Phosphor Thickness: 1.5 - 3.0
	phosphor_thickness_input.min_value = 1.5
	phosphor_thickness_input.max_value = 3.0
	phosphor_thickness_input.step = 0.01
	phosphor_thickness_range.text = \"1.5-3\"
	
	# Phosphor Strength: 0.05 - 0.25
	phosphor_strength_input.min_value = 0.05
	phosphor_strength_input.max_value = 0.25
	phosphor_strength_input.step = 0.01
	phosphor_strength_range.text = \".05-.25\"
	
	# Flicker Speed: 40 - 150
	flicker_speed_input.min_value = 40.0
	flicker_speed_input.max_value = 150.0
	flicker_speed_input.step = 1.0
	flicker_speed_range.text = \"40-150\"
	
	# Flicker Strength: 0.01 - 0.05
	flicker_strength_input.min_value = 0.01
	flicker_strength_input.max_value = 0.05
	flicker_strength_input.step = 0.001
	flicker_strength_range.text = \".01-.05\"

func _connect_signals():
	# Connect value_confirmed signals for all CRT parameters
	intensity_input.value_confirmed.connect(_on_intensity_confirmed)
	scanline_thickness_input.value_confirmed.connect(_on_scanline_thickness_confirmed)
	scanline_darkness_input.value_confirmed.connect(_on_scanline_darkness_confirmed)
	phosphor_thickness_input.value_confirmed.connect(_on_phosphor_thickness_confirmed)
	phosphor_strength_input.value_confirmed.connect(_on_phosphor_strength_confirmed)
	flicker_speed_input.value_confirmed.connect(_on_flicker_speed_confirmed)
	flicker_strength_input.value_confirmed.connect(_on_flicker_strength_confirmed)
	
	# Reset button
	reset_button.pressed.connect(_on_reset_pressed)

func _load_current_settings():
	# Load current values from SettingsGlobal into InputValue components
	intensity_input.value = SettingsGlobal.get_crt_intensity()
	intensity_input.update_text()
	
	scanline_thickness_input.value = SettingsGlobal.get_scanline_thickness()
	scanline_thickness_input.update_text()
	
	scanline_darkness_input.value = SettingsGlobal.get_scanline_darkness()
	scanline_darkness_input.update_text()
	
	phosphor_thickness_input.value = SettingsGlobal.get_phosphor_thickness()
	phosphor_thickness_input.update_text()
	
	phosphor_strength_input.value = SettingsGlobal.get_phosphor_strength()
	phosphor_strength_input.update_text()
	
	flicker_speed_input.value = SettingsGlobal.get_flicker_speed()
	flicker_speed_input.update_text()
	
	flicker_strength_input.value = SettingsGlobal.get_flicker_strength()
	flicker_strength_input.update_text()

# ========== VALUE CONFIRMED HANDLERS ==========

func _on_intensity_confirmed(value: float):
	SettingsGlobal.set_crt_intensity(value)
	print(\"CRT intensity set to: \", value)

func _on_scanline_thickness_confirmed(value: float):
	SettingsGlobal.set_scanline_thickness(value)
	print(\"Scanline thickness set to: \", value)

func _on_scanline_darkness_confirmed(value: float):
	SettingsGlobal.set_scanline_darkness(value)
	print(\"Scanline darkness set to: \", value)

func _on_phosphor_thickness_confirmed(value: float):
	SettingsGlobal.set_phosphor_thickness(value)
	print(\"Phosphor thickness set to: \", value)

func _on_phosphor_strength_confirmed(value: float):
	SettingsGlobal.set_phosphor_strength(value)
	print(\"Phosphor strength set to: \", value)

func _on_flicker_speed_confirmed(value: float):
	SettingsGlobal.set_flicker_speed(value)
	print(\"Flicker speed set to: \", value)

func _on_flicker_strength_confirmed(value: float):
	SettingsGlobal.set_flicker_strength(value)
	print(\"Flicker strength set to: \", value)

# ========== RESET FUNCTION ==========

func _on_reset_pressed():
	# Reset to default values from SettingsGlobal constants
	var defaults = SettingsGlobal.DEFAULT_CRT_SETTINGS
	
	intensity_input.value = defaults[\"intensity\"]
	intensity_input.update_text()
	
	scanline_thickness_input.value = defaults[\"scanline_thickness\"]
	scanline_thickness_input.update_text()
	
	scanline_darkness_input.value = defaults[\"scanline_darkness\"]
	scanline_darkness_input.update_text()
	
	phosphor_thickness_input.value = defaults[\"phosphor_thickness\"]
	phosphor_thickness_input.update_text()
	
	phosphor_strength_input.value = defaults[\"phosphor_strength\"]
	phosphor_strength_input.update_text()
	
	flicker_speed_input.value = defaults[\"flicker_speed\"]
	flicker_speed_input.update_text()
	
	flicker_strength_input.value = defaults[\"flicker_strength\"]
	flicker_strength_input.update_text()
	
	# Update settings with the reset values
	SettingsGlobal.set_crt_intensity(defaults[\"intensity\"])
	SettingsGlobal.set_scanline_thickness(defaults[\"scanline_thickness\"])
	SettingsGlobal.set_scanline_darkness(defaults[\"scanline_darkness\"])
	SettingsGlobal.set_phosphor_thickness(defaults[\"phosphor_thickness\"])
	SettingsGlobal.set_phosphor_strength(defaults[\"phosphor_strength\"])
	SettingsGlobal.set_flicker_speed(defaults[\"flicker_speed\"])
	SettingsGlobal.set_flicker_strength(defaults[\"flicker_strength\"])
	
	print(\"CRT shader settings reset to defaults\")
"

[sub_resource type="GDScript" id="GDScript_1xyqn"]
script/source = "extends VBoxContainer

@onready var resolutionOptionButton = $Option3/OptionButton # options items : [1280x720, 800x480, 640x480, 480x320]
@onready var shaderTextRatioOptionButton = $Option4/OptionButton # options items : [1:1, 1:2, 1:4]

func _ready():
	_connect_signals()
	_load_current_settings()

func _connect_signals():
	resolutionOptionButton.item_selected.connect(_on_resolution_selected)
	shaderTextRatioOptionButton.item_selected.connect(_on_text_scale_selected)

func _load_current_settings():
	# Load current resolution
	var current_resolution = SettingsGlobal.get_resolution()
	var resolution_text = str(current_resolution.x) + \"x\" + str(current_resolution.y)
	
	# Find and select the matching resolution option
	var resolution_index = _find_item_by_text(resolutionOptionButton, resolution_text)
	if resolution_index != -1:
		resolutionOptionButton.select(resolution_index)
	else:
		print(\"Warning: Current resolution not in options: \", resolution_text)
	
	# Load current text scale
	var current_scale = SettingsGlobal.get_shader_text_scale()
	var scale_text = \"1:\" + str(current_scale)
	
	# Find and select the matching text scale option
	var scale_index = _find_item_by_text(shaderTextRatioOptionButton, scale_text)
	if scale_index != -1:
		shaderTextRatioOptionButton.select(scale_index)
	else:
		print(\"Warning: Current text scale not in options: \", scale_text)

func _find_item_by_text(option_button: OptionButton, text: String) -> int:
	\"\"\"Find the index of an item by its text\"\"\"
	for i in range(option_button.get_item_count()):
		if option_button.get_item_text(i) == text:
			return i
	return -1

func _parse_resolution(text: String) -> Vector2i:
	\"\"\"Parse resolution string like '1280x720' into Vector2i\"\"\"
	var parts = text.split(\"x\")
	if parts.size() == 2:
		return Vector2i(int(parts[0]), int(parts[1]))
	return Vector2i(800, 480)  # Default fallback

func _parse_text_scale(text: String) -> int:
	\"\"\"Parse text scale string like '1:2' into integer scale\"\"\"
	var parts = text.split(\":\")
	if parts.size() == 2:
		return int(parts[1])
	return 1  # Default fallback

# ========== SIGNAL HANDLERS ==========

func _on_resolution_selected(index: int):
	\"\"\"Called when a resolution is selected from the dropdown\"\"\"
	var selected_text = resolutionOptionButton.get_item_text(index)
	var new_resolution = _parse_resolution(selected_text)
	
	SettingsGlobal.set_resolution(new_resolution)
	
	# Apply resolution immediately
	DisplayServer.window_set_size(new_resolution)
	
	print(\"Resolution set to: \", selected_text)

func _on_text_scale_selected(index: int):
	\"\"\"Called when a text scale is selected from the dropdown\"\"\"
	var selected_text = shaderTextRatioOptionButton.get_item_text(index)
	var new_scale = _parse_text_scale(selected_text)
	
	SettingsGlobal.set_shader_text_scale(new_scale)
	
	print(\"Shader text scale set to: \", selected_text)
"

