[sub_resource type="GDScript" id="GDScript_fnnis"]
script/source = "extends VBoxContainer

@onready var ManageUsersButton = $ButtonPanelUsers/ManageUsersButton
@onready var ManageUsersPanel = $\"../../SettingPopUpPanel/MC/ManageUsersPanel\"

@onready var ShaderSettingsButton = $ButtonPanelShader/ShaderSettingsButton
@onready var ShaderSettingsPanel = $\"../../SettingPopUpPanel/MC/ShaderSettingsPanel\"

@onready var GeneralSettingsButton = $ButtonPanelGeneral/GeneralSettingsButton
@onready var GeneralSettingsPanel = $\"../../SettingPopUpPanel/MC/GeneralSettingsPanel\"


var activeSetting: Panel = null
var activeButton: Button = null

func _ready():
	# Set all buttons to toggle mode
	ManageUsersButton.toggle_mode = true
	ShaderSettingsButton.toggle_mode = true
	
	# Connect toggled signals
	ManageUsersButton.toggled.connect(_on_manage_users_toggled)
	ShaderSettingsButton.toggled.connect(_on_shader_settings_toggled)
	GeneralSettingsButton.toggled.connect(_on_general_settings_toggled)
	
	# Initially hide all panels
	hide_all_panels()

func hide_all_panels():
	ManageUsersPanel.hide()
	ShaderSettingsPanel.hide()
	GeneralSettingsPanel.hide()
	activeSetting = null

func unpress_all_buttons():
	ManageUsersButton.set_pressed_no_signal(false)
	ShaderSettingsButton.set_pressed_no_signal(false)
	GeneralSettingsButton.set_pressed_no_signal(false)
	activeButton = null

func _on_manage_users_toggled(toggled_on: bool):
	if toggled_on:
		# Unpress all other buttons
		unpress_all_buttons()
		
		# Set this button as active
		ManageUsersButton.set_pressed_no_signal(true)
		activeButton = ManageUsersButton
		
		# Hide all panels and show the selected one
		hide_all_panels()
		ManageUsersPanel.show()
		activeSetting = ManageUsersPanel
	else:
		# If this button is being toggled off
		if activeButton == ManageUsersButton:
			hide_all_panels()
			activeButton = null

func _on_shader_settings_toggled(toggled_on: bool):
	if toggled_on:
		# Unpress all other buttons
		unpress_all_buttons()
		
		# Set this button as active
		ShaderSettingsButton.set_pressed_no_signal(true)
		activeButton = ShaderSettingsButton
		
		# Hide all panels and show the selected one
		hide_all_panels()
		ShaderSettingsPanel.show()
		activeSetting = ShaderSettingsPanel
	else:
		# If this button is being toggled off
		if activeButton == ShaderSettingsButton:
			hide_all_panels()
			activeButton = null

func _on_general_settings_toggled(toggled_on: bool):
	if toggled_on:
		# Unpress all other buttons
		unpress_all_buttons()
		
		# Set this button as active
		GeneralSettingsButton.set_pressed_no_signal(true)
		activeButton = GeneralSettingsButton
		
		# Hide all panels and show the selected one
		hide_all_panels()
		GeneralSettingsPanel.show()
		activeSetting = GeneralSettingsPanel
	else:
		# If this button is being toggled off
		if activeButton == GeneralSettingsButton:
			hide_all_panels()
			activeButton = null

# Helper: Method to get the currently active panel
func get_active_setting() -> Panel:
	return activeSetting
"

