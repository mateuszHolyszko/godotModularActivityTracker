script/source = "extends Control

signal data_loaded  # emitted when UI is fully initialized

# --------------------
# DATA
# --------------------
var session_model: SessionModel
var exercise_idx: int
var set_data: ExerciseSetResource
var previous_set: ExerciseSetResource

# --------------------
# UI NODES
# --------------------
@onready var previous_weight_label = $Panel/HC/MainPanel/VC/WeightPanel/HC/PreviousWeightPanel/VC/PreviousWeightLabel
@onready var previous_reps_label   = $Panel/HC/MainPanel/VC/RepsPanel/HC/PreviousRepsPanel/VC/PreviousRepsLabel
@onready var value_input_weight    = $Panel/HC/MainPanel/VC/WeightPanel/HC/InputWeightPanel/ValueInputWeight
@onready var value_input_reps      = $Panel/HC/MainPanel/VC/RepsPanel/HC/InputRepsPanel/ValueInputReps
@onready var set_num_label         = $Panel/HC/SetNumPanel/HC/SetNumLabel
@onready var add_set_button        = $AddSetButton

var _ui_initialized: bool = false

# ========================
# DATA ONLY: setup (safe to call deferred)
# ========================
func setup(set: ExerciseSetResource, model: SessionModel, idx: int) -> void:
	session_model = model
	exercise_idx = idx
	set_data = set
	print(\"RowSet: setup called for set\", set_data.set_number)

	if _ui_initialized:
		_initialize_ui()


# ========================
# READY
# ========================
func _ready() -> void:
	_ui_initialized = true
	_connect_signals()
	
	# Initialize UI if setup() was already called
	if set_data:
		_initialize_ui()
	# Otherwise setup() will call _initialize_ui() later
	print(\"RowSet: ready (UI nodes initialized)\")


# ========================
# SIGNALS
# ========================
func _connect_signals():
	if session_model:
		session_model.set_added.connect(_on_set_changed)
		session_model.set_removed.connect(_on_set_changed)
		session_model.set_edited.connect(_on_set_edited)


# ========================
# UI INITIALIZATION
# ========================
func _initialize_ui() -> void:
	if not set_data:
		return  # safety

	# set labels & inputs
	set_num_label.text = str(set_data.set_number)
	_load_previous_set()
	_apply_current_values()
	_refresh_add_button_visibility()

	# connect inputs/buttons
	value_input_weight.value_confirmed.connect(_on_weight_changed)
	value_input_reps.value_confirmed.connect(_on_reps_changed)
	add_set_button.pressed.connect(_on_add_set_pressed)

	# emit signal for any parent needing UI-ready notification
	data_loaded.emit()
	print(\"RowSet: UI initialized for set\", set_data.set_number)


func _load_previous_set() -> void:
	var previous_sets := SessionManager.find_most_recent_sets(set_data.exercise)

	previous_set = null
	for s in previous_sets:
		if s.set_number == set_data.set_number:
			previous_set = s
			break

	if previous_set != null:
		previous_weight_label.text = str(previous_set.weight)
		previous_reps_label.text   = str(previous_set.reps)
	else:
		previous_weight_label.text = \"-\"
		previous_reps_label.text   = \"-\"


func _apply_current_values() -> void:
	value_input_weight.value = set_data.weight
	value_input_reps.value   = set_data.reps


# ========================
# SIGNAL HANDLERS
# ========================
func _on_set_changed(idx, _a = null) -> void:
	if idx != exercise_idx:
		return
	_refresh_add_button_visibility()


func _on_set_edited(idx, set_number, updated_set) -> void:
	if idx != exercise_idx:
		return
	if set_number != set_data.set_number:
		return
	set_data = updated_set
	_apply_current_values()


# ========================
# UI LOGIC
# ========================
func _refresh_add_button_visibility() -> void:
	var total_sets: int = session_model.get_sets_for_exercise(exercise_idx).size()
	add_set_button.visible = (set_data.set_number == total_sets)
	print(\"RowSet\", set_data.set_number, \": add button visible =\", add_set_button.visible)


# ========================
# INPUT HANDLERS
# ========================
func _on_weight_changed(value) -> void:
	session_model.edit_set(
		exercise_idx,
		set_data.set_number,
		value,
		value_input_reps.value
	)


func _on_reps_changed(value) -> void:
	session_model.edit_set(
		exercise_idx,
		set_data.set_number,
		value_input_weight.value,
		value
	)


func _on_add_set_pressed() -> void:
	session_model.add_set(
		exercise_idx,
		value_input_weight.value,
		value_input_reps.value,
		int(Time.get_unix_time_from_system())
	)

func update_data(new_set: ExerciseSetResource) -> void:
	set_data = new_set
	if _ui_initialized:
		_apply_current_values()
		_refresh_add_button_visibility()
"

[sub_resource type="GDScript" id="GDScript_vch07"]
script/source = "extends Panel

@onready var root = $\"../../..\"
@onready var label = $HC/Label
@onready var set_num_label = $HC/SetNumLabel

func _ready():
	# Wait one frame to ensure all nodes are properly set up
	call_deferred(\"_try_connect_signal\")

func _try_connect_signal():
	# Check if root is valid now
	if root == null:
		print(\"Root is still null, will retry...\")
		await get_tree().create_timer(0.1).timeout
		_try_connect_signal()
		return
	
	# Now root should be valid
	if root.has_signal(\"data_loaded\"):
		if not root.data_loaded.is_connected(_on_data_loaded):
			root.data_loaded.connect(_on_data_loaded)
			#print(\"Successfully connected to data_loaded signal\")
	else:
		print(\"data_loaded signal not found on root\")

func _on_data_loaded():
	print(\"data_loaded signal received, applying styles\")
	
	# Double-check that all nodes are valid
	if root == null or root.set_data == null or root.set_data.exercise == null:
		print(\"Error: root or its data is null\")
		return
	
	var exercise = root.set_data.exercise
	
	var style = StyleBoxFlat.new()
	style.bg_color = MuscleData.MUSCLE_COLORS.get(exercise.target_muscle, Color.WHITE)
	style.set_border_width_all(2)  
	style.border_color = Color.WHITE
	
	self.add_theme_stylebox_override(\"normal\", style)
	self.add_theme_stylebox_override(\"hover\", style)
	self.add_theme_stylebox_override(\"pressed\", style)
	
	# Check if label and set_num_label are valid
	if label:
		label.add_theme_color_override(\"font_color\", Color.BLACK)
	if set_num_label:
		set_num_label.add_theme_color_override(\"font_color\", Color.BLACK)
	
	add_theme_stylebox_override(\"panel\", style)
"

