[sub_resource type="GDScript" id="GDScript_aww8w"]
script/source = "extends Control

signal node_ready 
signal set_initialized

# --------------------
# DATA
# --------------------
var session_model: SessionModel
var exercise_idx: int
var set_idx: int
var set_data: ExerciseSetResource
var previous_set: ExerciseSetResource
var edited_flag : bool = 0 # Use this flag when saving session (discard sets that havent been edited)

var exercise: ExerciseResource

# --------------------
# UI NODES
# --------------------
@onready var set_root 			   = $\".\"
@onready var previous_weight_label = $Panel/HC/MainPanel/VC/WeightPanel/HC/PreviousWeightPanel/VC/PreviousWeightLabel
@onready var previous_reps_label   = $Panel/HC/MainPanel/VC/RepsPanel/HC/PreviousRepsPanel/VC/PreviousRepsLabel
@onready var value_input_weight    = $Panel/HC/MainPanel/VC/WeightPanel/HC/InputWeightPanel/ValueInputWeight
@onready var value_input_reps      = $Panel/HC/MainPanel/VC/RepsPanel/HC/InputRepsPanel/ValueInputReps
@onready var set_num_label         = $Panel/HC/SetNumPanel/HC/SetNumLabel

# Adjust it if exercise is bodyweight
@onready var weight_label 		   = $Panel/HC/MainPanel/VC/WeightPanel/HC/LabelPanel/MC/Label

func _ready():
	# Emit node_ready signal at the end of _ready
	node_ready.emit()


# ========================
# INIT
# ========================
func initialize(model: SessionModel, idx: int, exercise_idx: int):
	session_model = model
	set_idx = idx
	self.exercise_idx = exercise_idx
	exercise = session_model.exercises[ exercise_idx ]
	
	previous_set = session_model.sets[exercise_idx][set_idx]
	print(\"				Retrived Set for set \",set_idx,\" R: \",previous_set.reps,\" W: \",previous_set.weight)
	
	_connect_signals()
	set_initialized.emit()

# ========================
# SIGNALS
# ========================
func _connect_signals():
	session_model.set_added.connect(_on_set_changed)
	session_model.set_removed.connect(_on_set_changed)
	session_model.set_edited.connect(_on_set_edited)
	
	# Connect to the node_ready signal
	node_ready.connect(_on_node_ready)


# ========================
# NODE READY HANDLER
# ========================
func _on_node_ready():
	# Set Labels
	set_num_label.text = str(set_idx + 1)
	previous_weight_label.text = str(previous_set.weight)
	previous_reps_label.text = str(previous_set.reps)
	
	# Set valueInputs to previous set values
	value_input_weight.value = previous_set.weight
	value_input_reps.value   = previous_set.reps
	
	# connect inputs/buttons
	value_input_weight.value_confirmed.connect(_on_weight_changed)
	value_input_reps.value_confirmed.connect(_on_reps_changed)
	
	# check if its bodyweight exercise if so take last know weight (saved in session model at .lastWeight)
	if exercise.bodyweight:
		weight_label.text = \"Weight\\nbw:\" + str(session_model.lastWeight)
	else:
		weight_label.text = \"Weight\"
	
	# Make set semi transparent to indicate it has not been edited yet
	set_root.modulate.a = 0.7  # Semi-transparent
	

# ========================
# SIGNAL HANDLERS
# ========================
func _on_set_changed(idx, _a = null) -> void:
	pass
	


func _on_set_edited(idx, set_number, updated_set) -> void:
	pass


# ========================
# INPUT HANDLERS
# ========================
func _on_weight_changed(value) -> void:
	session_model.edit_set(
		exercise_idx,
		set_idx,
		value,
		value_input_reps.value
	)
	# Make set opaqe to indicate it has been edited 
	set_root.modulate.a = 1
	# Switch flag
	edited_flag = 1


func _on_reps_changed(value) -> void:
	session_model.edit_set(
		exercise_idx,
		set_idx,
		value_input_weight.value,
		value
	)
	# Make set opaqe to indicate it has been edited 
	set_root.modulate.a = 1
	# Switch flag
	edited_flag = 1
"

