[sub_resource type="GDScript" id="GDScript_w1r7w"]
script/source = "extends TextureRect

@onready var root = $\"../../../../../../../../../..\"
@onready var ValueInputReps = $\"../../../../InputRepsPanel/ValueInputReps\"
var downArrow = \"res://assets/icons/chevron-down-svgrepo-com.svg\"
var upArrow = \"res://assets/icons/chevron-up-svgrepo-com.svg\"

# Called when the node enters the scene tree for the first time.
func _ready():
	ValueInputReps.value_confirmed.connect(_adjust_arrow_icon)

func _adjust_arrow_icon(numberOfReps):
	var session = root.session_model
	var exercise = session.exercises[ root.exercise_idx ]
	
	# Check if exercise.rep_range vector is bigger or smaller then number of reps, 
	# then adjust textureRect texture accordingly (or leave it blank if it fits the range)
	
	var rep_range = exercise.rep_range
	var min_reps = rep_range.x
	var max_reps = rep_range.y
	
	if numberOfReps < min_reps:
		texture = load(downArrow)
		NotificationManager.notify(\"Too few reps\\nRecommend lowering weight\")
	elif numberOfReps > max_reps:
		texture = load(upArrow)
		NotificationManager.notify(\"Too many reps\\nRecommend increasing weight\")
	else:
		texture = null
"

