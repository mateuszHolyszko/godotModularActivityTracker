script/source = "extends Button

signal node_ready 

# --------------------
# DATA
# --------------------
var session_model: SessionModel
var exercise_idx: int = -1  # Set default to -1 to indicate not initialized

func _ready():
	# Connect pressed signal early
	pressed.connect(_on_pressed)
	node_ready.emit()

# ========================
# INIT
# ========================
func initialize(model: SessionModel, idx: int):
	session_model = model
	exercise_idx = idx
	
	print(\"AddSetButton initialized with exercise_idx: \", exercise_idx)  # Debug print
	
	_connect_signals()

# ========================
# SIGNALS
# ========================
func _connect_signals():
	node_ready.connect(_on_node_ready)

# ========================
# NODE READY HANDLER
# ========================
func _on_node_ready():
	pass

# ========================
# BUTTON PRESSED HANDLER
# ========================
func _on_pressed():
	if exercise_idx == -1:
		print(\"Warning: Button not initialized yet!\")
		return
	add_set()

# ========================
# ACTIONS
# ========================
func add_set() -> void:
	print(\"AddSetButton for exercise_idx: \", exercise_idx)  # Debug print
	
	# Get the current sets for this exercise
	var current_sets = session_model.sets[exercise_idx] 
	
	var weight: float
	var reps: int
	
	# If this is the first set, initialize with 0,0
	if current_sets.is_empty():
		weight = 0.0
		reps = 0
	# If appending a new set, use previous set's values
	else:
		var previous_set = current_sets[-1]  # Get the last set
		weight = previous_set.weight
		reps = previous_set.reps
	
	# Add the new set
	session_model.add_set(
		exercise_idx,
		weight,
		reps,
		int(Time.get_unix_time_from_system())
	)
"

