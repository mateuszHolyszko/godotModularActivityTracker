[sub_resource type="GDScript" id="GDScript_x5ejq"]
script/source = "extends Control

signal program_pressed(program : HypertrophyProgramResource)

@onready var program_label = $Panel/HC/ProgramLabel
@onready var run_program_button = $Panel/HC/RunProgramButton

var program : HypertrophyProgramResource


func _ready():
	run_program_button.pressed.connect(_on_run_program_button_pressed)


func set_program(p : HypertrophyProgramResource):
	program = p
	program_label.text = program.name


func _on_run_program_button_pressed():
	if program != null:
		program_pressed.emit(program)
"

